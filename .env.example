# n8n Webhook Ayarları
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/demo-request
N8N_API_KEY=your-n8n-api-key

# Cloudflare Turnstile (https://dash.cloudflare.com)
# Secret key: sunucu tarafı doğrulama için (gizli tutulmalı)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Site key: istemci tarafı widget için (NEXT_PUBLIC_ prefix zorunlu)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Upstash Redis - Rate Limiting (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Site domain (Open Graph ve canonical URL için)
NEXT_PUBLIC_DOMAIN=https://www.yourdomain.com
